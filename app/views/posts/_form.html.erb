<%= form_with(model: post) do |form| %>
  <% if post.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(post.errors.count, "error") %> prohibited this post from being saved:</h2>

      <ul>
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :caption %>
    <%= form.text_field :caption %>
  </div>

  <div>
    <%= form.label :longitude %>
    <%= form.text_field :longitude %>
  </div>

  <div>
    <%= form.label :latitude %>
    <%= form.text_field :latitude %>
  </div>


  <div>
    <%= form.label :allow_comments %>
    <%= form.check_box :allow_comments %>
  </div>

  <div>
    <%= form.label :show_likes_count %>
    <%= form.check_box :show_likes_count %>
  </div>

  <div>
    <%= form.label :photos %>
    <%= form.file_field :photos, multiple: true %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
