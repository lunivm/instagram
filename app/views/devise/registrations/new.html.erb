<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: 'container login-sections d-flex flex-row justify-content-center align-items-center' }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <div class="login-section p-3">
    <div class="card text-center pt-5">
      <%= image_tag 'logo.png', class: 'logo-img card-img-top mx-auto' %>
      <a href="#" class="d-block mt-2 text-decoration-none fw-bold">
        <%= image_tag "facebook.png", class: "facebook" %>
        Log in with Facebook
      </a>
      <div class="d-flex align-items-center mt-1 justify-content-around">
        <span class="line-text">OR</span>
      </div>
      <div class="card-body">
        <div class="mb-3 mt-4">
          <%= f.email_field :email, autofocus: true, class: "form-control", placeholder: "Phone number or email" %>
        </div>
        <div class="mb-3 mt-4">
          <%= f.text_field :full_name, class: "form-control", placeholder: "Full name" %>
        </div>
        <div class="mb-3 mt-4">
          <%= f.text_field :username, class: "form-control", placeholder: "Username" %>
        </div>
        <div class="mb-3 mt-4">
          <%= f.text_field :phone_number, class: "form-control", placeholder: "Phone number" %>
        </div>
        <div class="mb-3">
          <%= f.password_field :password, class: "form-control", placeholder: "Password" %>
        </div>
        <div class="mb-3">
          <%= f.password_field :password_confirmation, class: "form-control", placeholder: "Password confirmation" %>
        </div>
        <%= f.submit "Sign up", class: "btn btn-primary w-100" %>
      </div>
      <a href="#" class="fs-6 d-block my-4 text-decoration-none">Forgot password?</a>
    </div>
    <div class="card text-center py-2 mt-3">
      <div class="card-body">
        Have an account?
        <%= link_to "Sign in", new_user_session_path, class: "fs-6 my-4 text-decoration-none" %>
      </div>
    </div>
  </div>
<% end %>

<%= render "devise/shared/links" %>
